# overwrite ls
if  command -v colorls &> /dev/null; then
    alias ls='colorls'
    compdef colorls='ls'
    
    # 優化：建立常見路徑名單，避免執行耗時的 gem which
    colorls_tab_complete=""
    possible_paths=(
        "/usr/lib/ruby/gems/3.4.0/gems/colorls-1.5.0/tab_complete.sh"
        "/usr/lib/ruby/gems/3.3.0/gems/colorls-1.4.6/tab_complete.sh"
        "/usr/local/lib/ruby/gems/3.4.0/gems/colorls-1.5.0/tab_complete.sh"
        "/usr/local/lib/ruby/gems/3.3.0/gems/colorls-1.4.6/tab_complete.sh"
        "$HOME/.local/share/gem/ruby/3.4.0/gems/colorls-1.5.0/tab_complete.sh"
        "$HOME/.local/share/gem/ruby/3.3.0/gems/colorls-1.4.6/tab_complete.sh"
    )
    for p in "${possible_paths[@]}"; do
        if [[ -f "$p" ]]; then
            colorls_tab_complete="$p"
            break
        fi
    done
    
    # 若常見路徑找不到，且有 gem 環境時，才 fallback 回 gem which
    if [[ -z "$colorls_tab_complete" ]] && command -v gem &> /dev/null; then
        colorls_path=$(gem which colorls 2>/dev/null)
        if [[ -n "$colorls_path" ]]; then
            # gem which 回傳的通常是 .../lib/colorls.rb，而 tab_complete.sh 在往上一層
            colorls_tab_complete="$(dirname "$(dirname "$colorls_path")")/tab_complete.sh"
            # 兼容：如果剛好就在 lib 內
            if [[ ! -f "$colorls_tab_complete" ]]; then
                colorls_tab_complete="$(dirname "$colorls_path")/tab_complete.sh"
            fi
        fi
    fi
    
    if [[ -n "$colorls_tab_complete" && -f "$colorls_tab_complete" ]]; then
        source "$colorls_tab_complete"
    fi
elif  command -v eza &> /dev/null; then
    zinit ice as"completion"
    zinit snippet https://github.com/eza-community/eza/blob/main/completions/zsh/_eza
    alias ls='eza --color=always --group --icons=always'
    #zinit light 'eza-community/eza'
elif  command -v exa &> /dev/null; then
    compdef exa='ls'
    alias ls='exa --color=always --group --icons'
fi

